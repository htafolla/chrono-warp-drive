# Dynamo MCP base URL — SSOT for governance + HTTP MCP harness.
DYNAMO_MCP_URL=https://mcp-production-80e2.up.railway.app

# 0xRay xray-governance MCP (omit endpoint_url in .xray/features.json).
# GOVERNANCE_ENDPOINT=https://mcp-production-80e2.up.railway.app/governance

# 0xRay consumer project root (optional — defaults to MCP cwd).
# XRAY_ROOT=/path/to/chrono-warp-drive

# Repertoire provider (memory_routing in .xray/features.json).
# REPERTOIRE_ROOT=/path/to/repertoire

# -----------------------------------------------------------------------------
# Dynamo UI / neural fusion (chrono-specific — P0.4 SSOT)
# -----------------------------------------------------------------------------

# NEURAL_FUSION_URL=https://neural-fusion-backend-production.up.railway.app
