{
  "version": 2,
  "builds": [
    { "src": "index.ts", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/index.ts" }
  ],
  "functions": {
    "index.ts": {
      // Neural Fusion + solar training on cold start needs a little extra headroom.
      // Training is only 25 epochs of a 6-16-8-1 net + one NOAA fetch + stellar lib load.
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
